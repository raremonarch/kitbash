#!/bin/bash
# Kitbash Configuration Template
# Copy this file to kit.conf and customize for your system:
#   cp kit.conf.example kit.conf

# ==============================================================================
# REQUIRED SETTINGS
# ==============================================================================

_hostname='desktop'     # System hostname
_terminal='alacritty'   # Default terminal (alacritty, gnome-terminal, konsole, etc.)
_editor='vim'           # Default editor (vim, nano, code, etc.)

# ==============================================================================
# APPEARANCE
# ==============================================================================

# Wallpaper (can be local path or predefined name from _wallpaper_definitions)
_wallpaper='neon-blue-circle'
_wallpaper_targets=("desktop" "lock" "login")  # Where to apply wallpaper

# System accent color (used by sddm theme and other components)
_accent_color='#ca9ee6'              # Default purple — override per system

# Cursor theme and size
_cursor='breeze_cursors'             # Cursor theme name
_cursor_size='20'                    # Cursor size in pixels

# Font (name from _font_definitions or system font name)
_font='AudioLink Mono'

# ==============================================================================
# SYSTEM SETTINGS
# ==============================================================================

# Sudo timeout in minutes (-1 for no timeout until reboot, or number of minutes)
_sudo_timeout=15

# Hibernation via swapfile (ext4 only)
_hibernate=false                     # Enable hibernation setup
# _hibernate_swap_size=8192          # Swapfile size in MB (default: auto-match RAM)
# _hibernate_swapfile=/swapfile      # Swapfile path (default: /swapfile)
# _hibernate_boot_entry=/boot/loader/entries/arch.conf  # systemd-boot entry

# ==============================================================================
# TIER 0: DOTFILES MANAGEMENT (runs first)
# ==============================================================================

_dotfiles=true                       # Clone dotfiles repo (requires _dotfiles_repo)

# ==============================================================================
# TIER 1: SYSTEM FUNDAMENTALS
# ==============================================================================

# (hostname, editor, sudo_timeout, jq are configured above or auto-enabled)

# ==============================================================================
# TIER 2: DESKTOP ENVIRONMENT
# ==============================================================================

_brightnessctl=false                 # Screen brightness control utility
_greetd=false                        # greetd display manager with gtkgreet
_hyprland=false                      # Hyprland dynamic tiling compositor
_niri=false                          # Niri scrollable-tiling Wayland compositor
_sddm=false                          # SDDM display manager with Wayland support
_theme=false                         # Catppuccin Mocha GTK theme for dark mode
_thunar=false                        # Lightweight GTK file manager (Xfce)
_waybar=true                         # Wayland status bar (Sway, Niri, Hyprland)

# ==============================================================================
# TIER 3: PACKAGE REPOSITORIES
# ==============================================================================

_google_chrome=true                  # Google Chrome via official Google repository
_vscode=true                         # VS Code via official Microsoft repository

# ==============================================================================
# TIER 4: CORE USER TOOLS
# ==============================================================================

_alacritty=false                     # Fast, GPU-accelerated terminal emulator
_copyq=false                         # Advanced clipboard manager with history

# ==============================================================================
# TIER 5: APPLICATIONS
# ==============================================================================

_awscli=false                        # AWS CLI v2
_claude=false                        # Claude Code CLI (AI assistant)
_discord=false                       # Discord chat and voice client
_docker=false                        # Docker Engine with Compose plugin
_dropbox=false                       # Dropbox desktop client
_easyeffects=false                   # PipeWire audio processor with LV2 plugins
_firefox=false                       # Firefox web browser
_gnome_boxes=false                   # GNOME Boxes virtualization
_imagemagick=false                   # ImageMagick image manipulation suite
_nordvpn=false                       # NordVPN client
_obsidian=true                       # Obsidian markdown knowledge base editor
_ollama=false                        # Ollama AI model runtime
_qpwgraph=false                      # PipeWire graph editor for audio routing
_steam=false                         # Steam gaming platform
_synology=true                       # Synology Drive client
_zoom=false                          # Zoom video conferencing

# ==============================================================================
# TIER 6: SYSTEM SERVICES
# ==============================================================================

_mounts=false                        # Configure CIFS/NFS network and local mounts

# ==============================================================================
# DOTFILES REPOSITORY (only used if _dotfiles=true)
# ==============================================================================

# _dotfiles_repo="yourusername/dotfiles"

# ==============================================================================
# MOUNT CONFIGURATION (only used if _mounts=true)
# ==============================================================================

# Network mounts
# Format: "remote_share:mount_point:home_symlink,option1=value,option2=value"
_network_mounts=(
    # CIFS/SMB example:
    "//nimbus/media:/mnt/nimbus/media:~/nimbus-media,credfile=~/.smbcreds"
    #
    # NFS example (no credentials):
    # "nfsserver:/export/path:/mnt/nfs:~/nfs"
)

# Local media drives
# Format: "device_uuid:mount_point:,option1=value,option2=value"
_local_media=(
    # Example (find UUID with: lsblk -f):
    # "UUID=ABCD-1234:/media/mydrive:"
)

# ==============================================================================
# CUSTOM RESOURCES
# ==============================================================================

# Wallpaper definitions (name:url pairs)
_wallpaper_definitions=(
    # Example:
    "neon-blue-circle:https://i.imgur.com/xeYkH88.jpeg"
)

# Font definitions (name:url pairs for downloadable fonts)
_font_definitions=(
    # Example (must be a .zip file containing .ttf or .otf files):
    "AudioLink Mono:https://audiolink.dev/gallery/AudioLinkMono.zip"
    "Bedstead:https://bjh21.me.uk/bedstead/bedstead-3.252.zip"
    "Chivo:https://www.omnibus-type.com/wp-content/uploads/Chivo.zip"
)
